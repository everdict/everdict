# Live e2e (final service-topology rung): real browser-use as an everdict service-topology front-door image.
# POST /runs {task, browser_cdp_url} → drive real headless Chromium via a real LLM (LiteLLM) → expose the
# visited URL / extracted text via /observe. everdict's ServiceTopologyBackend deploys/drives/observes/grades this front-door.
#   docker build -t everdict-browseruse:demo -f scripts/live/Dockerfile.browseruse scripts/live
# The key / base URL are injected only via runtime env (OPENAI_API_KEY/OPENAI_BASE_URL) — never committed.
FROM mcr.microsoft.com/playwright/python:v1.49.0-noble
ENV PIP_NO_CACHE_DIR=1 DEBIAN_FRONTEND=noninteractive
# browser-use 0.13.x + aiohttp. Browser binaries reuse /ms-playwright from the playwright base image as-is
# (0.13 drives chromium over CDP via cdp_use rather than the playwright module — the server points executable_path at that chromium).
RUN pip install --no-cache-dir "browser-use>=0.13,<0.14" aiohttp
RUN python -c "import importlib.metadata as m; print('INTROSPECT browser-use', m.version('browser-use'))"
RUN python - <<'PY'
import browser_use
try:
    from browser_use.agent.views import AgentHistoryList as H
except Exception:
    H = None
print("INTROSPECT HISTORY", sorted(x for x in dir(H) if not x.startswith("_")) if H else "n/a")
PY
COPY browseruse_server.py /srv/server.py
EXPOSE 8080
CMD ["bash","-lc","Xvfb :99 -screen 0 1280x1024x24 >/tmp/xvfb.log 2>&1 & export DISPLAY=:99; exec python /srv/server.py"]
