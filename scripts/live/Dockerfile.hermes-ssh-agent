# everdict os-use dispatch image (SLICE 76/83): hermes-desktop + sshd + two reference desktop agents (baked in).
# Build context = hermes-desktop clone. Before building, copy the two agents into the context (agent.cjs, agent-settings.cjs).
#   git clone --depth 1 https://github.com/fathah/hermes-desktop /tmp/hermes-desktop
#   cp examples/agents/desktop-ssh-agent.cjs /tmp/hermes-desktop/agent.cjs
#   cp examples/agents/desktop-ssh-settings-agent.cjs /tmp/hermes-desktop/agent-settings.cjs
#   cp scripts/live/Dockerfile.hermes-ssh-agent /tmp/hermes-desktop/
#   docker build -f /tmp/hermes-desktop/Dockerfile.hermes-ssh-agent -t everdict-hermes-dispatch:demo /tmp/hermes-desktop
FROM node:22-bookworm

RUN apt-get update && apt-get install -y --no-install-recommends \
      xvfb scrot xdotool wmctrl x11-utils \
      openssh-server openssh-client \
      libnss3 libatk1.0-0 libatk-bridge2.0-0 libcups2 libdrm2 libxkbcommon0 \
      libxcomposite1 libxdamage1 libxfixes3 libxrandr2 libgbm1 libasound2 \
      libpango-1.0-0 libcairo2 libatspi2.0-0 libgtk-3-0 libxshmfence1 \
      fonts-liberation ca-certificates \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app
COPY package.json package-lock.json ./
RUN npm install --no-audit --no-fund
COPY . .
RUN npm run build
# Two reference desktop agents (the command harness runs them as `node /agent.cjs` / `node /agent-settings.cjs` respectively).
COPY agent.cjs /agent.cjs
COPY agent-settings.cjs /agent-settings.cjs

ENTRYPOINT ["sleep", "infinity"]
