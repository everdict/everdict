# assay os-use 디스패치 이미지 (SLICE 76): hermes-desktop + sshd + 레퍼런스 데스크탑 에이전트(baked).
# 빌드 컨텍스트 = hermes-desktop 클론. 빌드 전에 examples/agents/desktop-ssh-agent.cjs 를 컨텍스트에 agent.cjs 로 복사.
#   git clone --depth 1 https://github.com/fathah/hermes-desktop /tmp/hermes-desktop
#   cp examples/agents/desktop-ssh-agent.cjs /tmp/hermes-desktop/agent.cjs
#   cp scripts/live/Dockerfile.hermes-ssh-agent /tmp/hermes-desktop/
#   docker build -f /tmp/hermes-desktop/Dockerfile.hermes-ssh-agent -t assay-hermes-dispatch:demo /tmp/hermes-desktop
FROM node:22-bookworm

RUN apt-get update && apt-get install -y --no-install-recommends \
      xvfb scrot xdotool wmctrl x11-utils \
      openssh-server openssh-client \
      libnss3 libatk1.0-0 libatk-bridge2.0-0 libcups2 libdrm2 libxkbcommon0 \
      libxcomposite1 libxdamage1 libxfixes3 libxrandr2 libgbm1 libasound2 \
      libpango-1.0-0 libcairo2 libatspi2.0-0 libgtk-3-0 libxshmfence1 \
      fonts-liberation ca-certificates \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app
COPY package.json package-lock.json ./
RUN npm install --no-audit --no-fund
COPY . .
RUN npm run build
# 레퍼런스 데스크탑 에이전트(command 하니스가 `node /agent.cjs {{task}}` 로 실행).
COPY agent.cjs /agent.cjs

ENTRYPOINT ["sleep", "infinity"]
