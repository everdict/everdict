# Hermes Agent (NousResearch/hermes-agent) backend image — the same engine the hermes-desktop (fathah/hermes-desktop) app drives.
# Installed via the same official install.sh the desktop app uses on first run (--skip-setup, non-interactive). The LLM provider
# is configured via runtime env (provider=custom → our LiteLLM, OpenAI-compatible) — the key is not baked in, injected via HERMES_API_KEY.
# `hermes -z "<task>"` = headless one-shot (run a single task, print only the final answer) → used to measure pinch-style benchmark tasks.
#   docker build -t everdict-hermes-agent:demo -f scripts/live/Dockerfile.hermes-agent scripts/live
#   docker run --rm --network=host -e HERMES_API_KEY=$LITELLM_KEY -e HERMES_BASE_URL=http://localhost:4000/v1 \
#     -e HERMES_MODEL=gpt-5.4-mini everdict-hermes-agent:demo hermes -z "Write a commit message for ..." --yolo
FROM node:22-bookworm
RUN apt-get update && apt-get install -y --no-install-recommends \
      curl git ripgrep ffmpeg ca-certificates python3 \
    && rm -rf /var/lib/apt/lists/*
RUN curl -fsSL https://hermes-agent.nousresearch.com/install.sh | bash -s -- --skip-setup
COPY hermes-agent-entrypoint.sh /usr/local/bin/hermes-configure
RUN chmod +x /usr/local/bin/hermes-configure
ENTRYPOINT ["/usr/local/bin/hermes-configure"]
CMD ["hermes", "--version"]
