# Hermes Agent (NousResearch/hermes-agent) 백엔드 이미지 — hermes-desktop(fathah/hermes-desktop) 앱이 구동하는 그 엔진.
# 데스크탑 앱이 first-run 에 쓰는 동일한 공식 install.sh 로 설치(--skip-setup, 비대화식). LLM provider 는 런타임 env 로
# 구성(provider=custom → 우리 LiteLLM, OpenAI-compatible) — 키는 굽지 않고 HERMES_API_KEY 로 주입.
# `hermes -z "<task>"` = 헤드리스 one-shot(단일 태스크 실행 후 최종 답만 출력) → pinch 류 벤치마크 태스크 측정에 사용.
#   docker build -t assay-hermes-agent:demo -f scripts/live/Dockerfile.hermes-agent scripts/live
#   docker run --rm --network=host -e HERMES_API_KEY=$LITELLM_KEY -e HERMES_BASE_URL=http://localhost:4000/v1 \
#     -e HERMES_MODEL=gpt-5.4-mini assay-hermes-agent:demo hermes -z "Write a commit message for ..." --yolo
FROM node:22-bookworm
RUN apt-get update && apt-get install -y --no-install-recommends \
      curl git ripgrep ffmpeg ca-certificates python3 \
    && rm -rf /var/lib/apt/lists/*
RUN curl -fsSL https://hermes-agent.nousresearch.com/install.sh | bash -s -- --skip-setup
COPY hermes-agent-entrypoint.sh /usr/local/bin/hermes-configure
RUN chmod +x /usr/local/bin/hermes-configure
ENTRYPOINT ["/usr/local/bin/hermes-configure"]
CMD ["hermes", "--version"]
