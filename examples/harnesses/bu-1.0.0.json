{
  "kind": "service",
  "id": "bu",
  "version": "1.0.0",
  "services": [
    {
      "name": "agent-server",
      "image": "mendhak/http-https-echo:latest",
      "port": 8080,
      "needs": [],
      "perRun": ["thread_id"],
      "replicas": 1
    }
  ],
  "dependencies": [{ "store": "postgres", "role": "checkpoints", "isolateBy": "thread_id" }],
  "target": { "kind": "browser", "engine": "chromium", "lifecycle": "per-case-instance", "observe": ["dom", "url"] },
  "frontDoor": { "service": "agent-server", "submit": "POST /runs" },
  "traceSource": { "kind": "mlflow", "endpoint": "http://127.0.0.1:5501" }
}
