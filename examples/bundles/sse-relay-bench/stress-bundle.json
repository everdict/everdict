{
  "id": "sse-relay-stress",
  "version": "1.0.0",
  "description": "Stress-matrix companions to sse-relay-bench: (1) sse-relay-bench-win — the same topology but its client-host REQUIRES a Windows node (requires.os), so its jobs must route only to runners advertising os-windows; (2) sh-bench — a deterministic command harness (LocalDriver, no docker) as CPU/process noise on the same fleet. Reuses the sse-relay images (build them first, see README.md).",
  "harnessTemplates": [
    {
      "kind": "service",
      "category": "topology",
      "id": "sse-relay-bench-win",
      "version": "1",
      "services": [
        {
          "name": "command",
          "image": "sse-relay-command:v1",
          "port": 8000,
          "needs": [],
          "perRun": [],
          "replicas": 1,
          "env": { "MESSAGE_COUNT": "24", "PUBLISH_INTERVAL_MS": "200" },
          "readiness": { "timeoutMs": 120000, "intervalMs": 1000 }
        },
        {
          "name": "relay",
          "image": "sse-relay-relay:v1",
          "port": 8001,
          "needs": [],
          "perRun": [],
          "replicas": 1,
          "env": {},
          "readiness": { "timeoutMs": 120000, "intervalMs": 1000 }
        },
        {
          "name": "client-host",
          "image": "sse-relay-client-host:v1",
          "port": 8002,
          "needs": ["relay"],
          "perRun": [],
          "replicas": 1,
          "env": { "RELAY_URL": "{{relay.url}}" },
          "readiness": { "timeoutMs": 180000, "intervalMs": 1000 },
          "requires": { "os": "windows" }
        }
      ],
      "dependencies": [{ "store": "redis", "role": "bus", "isolateBy": "key-prefix" }],
      "target": {
        "kind": "browser",
        "engine": "chromium",
        "delivery": { "mode": "sentinel", "path": "observation" },
        "acquire": {
          "mode": "service",
          "service": "client-host",
          "open": "POST /sessions/{key_prefix}",
          "coordinates": { "session_id": "session_id" },
          "close": "DELETE /sessions/{session_id}",
          "ready": {
            "service": "relay",
            "poll": "GET /subscribed/{key_prefix}:chat:{session_id}",
            "intervalMs": 500,
            "timeoutMs": 120000
          }
        }
      },
      "frontDoor": {
        "service": "command",
        "submit": "POST /runs",
        "request": {
          "bodyTemplate": {
            "run_id": "{{run_id}}",
            "session_id": "{{session_id}}",
            "key_prefix": "{{key_prefix}}",
            "task": "{{task}}"
          }
        },
        "completion": {
          "mode": "poll",
          "statusPath": "GET /runs/{run_id}",
          "done": { "field": "status", "equals": "done" },
          "failed": { "field": "status", "equals": "failed" },
          "intervalMs": 1000,
          "timeoutMs": 300000
        },
        "traceInline": { "path": "trace" }
      },
      "traceSource": { "kind": "otel", "endpoint": "http://127.0.0.1:9" }
    },
    {
      "kind": "command",
      "category": "cli-agent",
      "id": "sh-bench",
      "version": "1",
      "setup": [],
      "command": "bash -lc \"echo {{task}} > out.txt && cat out.txt\"",
      "env": {},
      "trace": { "kind": "none" }
    }
  ],
  "harnesses": [
    {
      "template": { "id": "sse-relay-bench-win", "version": "1" },
      "id": "sse-relay-bench-win",
      "version": "1.0.0",
      "pins": {
        "command": "sse-relay-command:v1",
        "relay": "sse-relay-relay:v1",
        "client-host": "sse-relay-client-host:v1"
      }
    },
    {
      "template": { "id": "sh-bench", "version": "1" },
      "id": "sh-bench",
      "version": "1.0.0",
      "pins": {}
    }
  ],
  "datasets": [
    {
      "id": "sh-echo-parallel",
      "version": "1.0.0",
      "description": "8 deterministic command cases (echo to a file, verified by tests-pass) — in-process LocalDriver noise for the stress matrix.",
      "cases": [
        {
          "id": "cmd-0",
          "env": { "kind": "repo", "source": { "files": {} } },
          "task": "stress-echo-0",
          "graders": [{ "id": "tests-pass", "config": { "cmd": "grep -q stress-echo out.txt" } }],
          "timeoutSec": 300,
          "tags": ["stress", "command"]
        },
        {
          "id": "cmd-1",
          "env": { "kind": "repo", "source": { "files": {} } },
          "task": "stress-echo-1",
          "graders": [{ "id": "tests-pass", "config": { "cmd": "grep -q stress-echo out.txt" } }],
          "timeoutSec": 300,
          "tags": ["stress", "command"]
        },
        {
          "id": "cmd-2",
          "env": { "kind": "repo", "source": { "files": {} } },
          "task": "stress-echo-2",
          "graders": [{ "id": "tests-pass", "config": { "cmd": "grep -q stress-echo out.txt" } }],
          "timeoutSec": 300,
          "tags": ["stress", "command"]
        },
        {
          "id": "cmd-3",
          "env": { "kind": "repo", "source": { "files": {} } },
          "task": "stress-echo-3",
          "graders": [{ "id": "tests-pass", "config": { "cmd": "grep -q stress-echo out.txt" } }],
          "timeoutSec": 300,
          "tags": ["stress", "command"]
        },
        {
          "id": "cmd-4",
          "env": { "kind": "repo", "source": { "files": {} } },
          "task": "stress-echo-4",
          "graders": [{ "id": "tests-pass", "config": { "cmd": "grep -q stress-echo out.txt" } }],
          "timeoutSec": 300,
          "tags": ["stress", "command"]
        },
        {
          "id": "cmd-5",
          "env": { "kind": "repo", "source": { "files": {} } },
          "task": "stress-echo-5",
          "graders": [{ "id": "tests-pass", "config": { "cmd": "grep -q stress-echo out.txt" } }],
          "timeoutSec": 300,
          "tags": ["stress", "command"]
        },
        {
          "id": "cmd-6",
          "env": { "kind": "repo", "source": { "files": {} } },
          "task": "stress-echo-6",
          "graders": [{ "id": "tests-pass", "config": { "cmd": "grep -q stress-echo out.txt" } }],
          "timeoutSec": 300,
          "tags": ["stress", "command"]
        },
        {
          "id": "cmd-7",
          "env": { "kind": "repo", "source": { "files": {} } },
          "task": "stress-echo-7",
          "graders": [{ "id": "tests-pass", "config": { "cmd": "grep -q stress-echo out.txt" } }],
          "timeoutSec": 300,
          "tags": ["stress", "command"]
        }
      ],
      "tags": ["stress", "command"]
    }
  ]
}
