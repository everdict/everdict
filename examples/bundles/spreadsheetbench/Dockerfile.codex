# SpreadsheetBench 를 codex 에이전트로 수행하는 이미지 = spreadsheetbench:v1(툴체인 + grader) + node + codex.
# 에이전트(codex)와 채점 툴체인(libreoffice+openpyxl+sbench_grade+recalc)이 한 컨테이너에 있어야 하므로 결합한다.
# codex 인증: 러너가 ~/.codex 를 /codex 로 바인드 마운트(머신 ChatGPT 로그인 = own-pays, API 키 불필요) → CODEX_HOME=/codex.
# codex 자체 linux-sandbox 는 컨테이너 안에서 실패(중첩 seccomp/landlock) → 하니스 command 에서
# `--dangerously-bypass-approvals-and-sandbox` 로 끈다(격리는 컨테이너가 제공).
# 참조(빌드는 각자/CI): docker build -t spreadsheetbench-codex:v1 -f Dockerfile.codex examples/bundles/spreadsheetbench
FROM spreadsheetbench:v1

# node 22 + codex CLI(네이티브 바이너리 동봉 npm 패키지).
RUN apt-get update \
  && apt-get install -y --no-install-recommends curl ca-certificates \
  && curl -fsSL https://deb.nodesource.com/setup_22.x | bash - \
  && apt-get install -y --no-install-recommends nodejs \
  && npm i -g @openai/codex@0.142.3 \
  && npm cache clean --force \
  && apt-get purge -y curl && apt-get autoremove -y \
  && rm -rf /var/lib/apt/lists/*

ENV CODEX_HOME=/codex
WORKDIR /everdict
