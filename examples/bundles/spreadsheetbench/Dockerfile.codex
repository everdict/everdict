# Image that runs SpreadsheetBench with the codex agent = spreadsheetbench:v1 (toolchain + grader) + node + codex.
# The agent (codex) and the scoring toolchain (libreoffice+openpyxl+sbench_grade+recalc) must be in one container, so they are combined.
# codex auth: the runner bind-mounts ~/.codex at /codex (machine ChatGPT login = own-pays, no API key) → CODEX_HOME=/codex.
# codex's own linux-sandbox fails inside a container (nested seccomp/landlock) → turn it off in the harness command with
# `--dangerously-bypass-approvals-and-sandbox` (isolation is provided by the container).
# For reference (build it yourself / in CI): docker build -t spreadsheetbench-codex:v1 -f Dockerfile.codex examples/bundles/spreadsheetbench
FROM spreadsheetbench:v1

# node 22 + codex CLI (an npm package that bundles the native binary).
RUN apt-get update \
  && apt-get install -y --no-install-recommends curl ca-certificates \
  && curl -fsSL https://deb.nodesource.com/setup_22.x | bash - \
  && apt-get install -y --no-install-recommends nodejs \
  && npm i -g @openai/codex@0.142.3 \
  && npm cache clean --force \
  && apt-get purge -y curl && apt-get autoremove -y \
  && rm -rf /var/lib/apt/lists/*

ENV CODEX_HOME=/codex
WORKDIR /everdict
