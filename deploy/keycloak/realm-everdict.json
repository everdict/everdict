{
  "realm": "everdict",
  "enabled": true,
  "sslRequired": "none",
  "roles": {
    "realm": [{ "name": "viewer" }, { "name": "member" }, { "name": "admin" }]
  },
  "groups": [
    {
      "name": "workspaces",
      "subGroups": [
        { "name": "acme", "attributes": { "workspace": ["acme"] } },
        { "name": "globex", "attributes": { "workspace": ["globex"] } }
      ]
    }
  ],
  "clients": [
    {
      "clientId": "everdict-web",
      "enabled": true,
      "secret": "everdict-web-secret",
      "publicClient": false,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "redirectUris": ["http://localhost:3001/*"],
      "webOrigins": ["http://localhost:3001"],
      "protocolMappers": [
        {
          "name": "workspace",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "config": {
            "user.attribute": "workspace",
            "claim.name": "workspace",
            "jsonType.label": "String",
            "access.token.claim": "true",
            "id.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "everdict-mcp",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "fullScopeAllowed": true,
      "redirectUris": ["http://localhost/*", "http://127.0.0.1/*", "http://localhost:*/*", "https://localhost/*"],
      "webOrigins": ["+"],
      "attributes": { "pkce.code.challenge.method": "S256" },
      "protocolMappers": [
        {
          "name": "workspace",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "config": {
            "user.attribute": "workspace",
            "claim.name": "workspace",
            "jsonType.label": "String",
            "access.token.claim": "true",
            "id.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    }
  ],
  "users": [
    {
      "username": "alice",
      "enabled": true,
      "email": "alice@acme.test",
      "emailVerified": true,
      "firstName": "Alice",
      "lastName": "Acme",
      "attributes": { "workspace": ["acme"] },
      "credentials": [{ "type": "password", "value": "alice", "temporary": false }],
      "realmRoles": ["member"]
    },
    {
      "username": "carol",
      "enabled": true,
      "email": "carol@acme.test",
      "emailVerified": true,
      "firstName": "Carol",
      "lastName": "Acme",
      "attributes": { "workspace": ["acme"] },
      "credentials": [{ "type": "password", "value": "carol", "temporary": false }],
      "realmRoles": ["admin"]
    },
    {
      "username": "dave",
      "enabled": true,
      "email": "dave@globex.test",
      "emailVerified": true,
      "firstName": "Dave",
      "lastName": "Globex",
      "attributes": { "workspace": ["globex"] },
      "credentials": [{ "type": "password", "value": "dave", "temporary": false }],
      "realmRoles": ["member"]
    }
  ]
}
