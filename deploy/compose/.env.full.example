# env for deploy/compose/docker-compose.full.yaml — the full, nothing-in-memory, Temporal-backed stack.
#   cp deploy/compose/.env.full.example deploy/compose/.env
#   docker compose -f deploy/compose/docker-compose.full.yaml --env-file deploy/compose/.env up -d --build
#
# Required before first `up`: POSTGRES_PASSWORD, EVERDICT_SECRETS_KEY, EVERDICT_INTERNAL_TOKEN.

# ── Image tag (GHCR api/web). Ignored under `up --build` (builds from source). Pin a release e.g. 0.1.0. ────────
EVERDICT_VERSION=latest

# ── Ports (host side) ──────────────────────────────────────────
WEB_PORT=3001
API_PORT=8787
POSTGRES_PORT=5432
TEMPORAL_PORT=7233
TEMPORAL_UI_PORT=8233
KEYCLOAK_PORT=8080

# ── Postgres (shared by the control plane AND Temporal) — password REQUIRED ────────────────────────────────────
POSTGRES_USER=everdict
POSTGRES_PASSWORD=change-me-postgres
POSTGRES_DB=everdict

# ── Temporal image tags — pin these; verify the tags exist for your platform before first run ──────────────────
# auto-setup follows Temporal server releases (e.g. 1.26.2 / 1.27.2). ui follows its own line (e.g. 2.34.0).
TEMPORAL_VERSION=1.27.2
TEMPORAL_UI_VERSION=2.34.0

# ── Control-plane API — REQUIRED secrets ───────────────────────
# Secret at-rest encryption KEK (base64, 32 bytes):  openssl rand -base64 32
EVERDICT_SECRETS_KEY=
# Guard token for /internal/** (Temporal worker→API bridge + tenant-key minting):  openssl rand -hex 32
EVERDICT_INTERNAL_TOKEN=

# Idle timeout (ms) before a parked self-hosted job with no lease/heartbeat is rejected as no_runner. Default 5 min.
EVERDICT_SELF_HOSTED_QUEUE_TIMEOUT_MS=300000

# ── Externally reachable URLs ──────────────────────────────────
# The API base reachable from OUTSIDE the compose network — used for: the front-door callback rendezvous target,
# GitHub App install callback, Mattermost inbound, and live-trace deep-links. On a real host use its LAN IP/DNS,
# NOT localhost (a self-hosted runner on another machine must reach it). Leave empty to fall back to http://api:8787
# (only works for in-network topology backends; off-host self-hosted runners then can't post callbacks).
API_PUBLIC_URL=http://localhost:8787
# The web base the browser is sent back to (and Auth.js AUTH_URL). Leave empty for the dev default.
WEB_BASE_URL=http://localhost:3001

# ── Optional: limits / managed backend / local claude-code run auth ────────────────────────────────────────────
# Per-tenant concurrent-run ceiling (empty = unlimited).
EVERDICT_TENANT_RUNS=
# Agent image for managed (nomad/k8s) backends — not needed for local/self-hosted execution.
EVERDICT_AGENT_IMAGE=
# Only if the local backend runs the claude-code harness in-process (can be replaced by workspace secrets).
ANTHROPIC_API_KEY=
CLAUDE_CODE_OAUTH_TOKEN=

# ── Optional: interactive browser sessions (browser login profiles) ────────────────────────────────────────────
# Off by default. Set 1 to enable the interactive login browser + profile capture (Settings › Browser profiles).
EVERDICT_BROWSER_SESSIONS=
# Provisioner. RECOMMENDED for this containerized stack: `remote` — the api LEASES a whole browser from the
# `browser` sidecar pool over the compose network. No Docker socket, no host Chrome. Start the sidecar with the
# `browser` compose profile:  docker compose -f docker-compose.full.yaml --profile browser up -d
# (`docker` instead launches a container per session — needs the socket mount on the api AND a host-run control
#  plane; leave empty to fall back to the dev host-Chrome provisioner.)
EVERDICT_BROWSER_PROVISIONER=remote
# remote pool: comma-separated CDP bases of the browser sidecars (reachable from the api by service name). Add
# more sidecars (browser2, browser3, …) and list them here to raise concurrency — one browser is leased per session.
EVERDICT_BROWSER_CDP_POOL=http://browser:9222
# Browser image override (air-gapped/mirror deployments; digest-pinned) — empty = the pinned default image. Applies
# to both the `browser` sidecar (remote) and the launched container (docker).
EVERDICT_BROWSER_IMAGE=
# `docker` provisioner only: the network the launched browser container joins (must be one the api is on).
EVERDICT_BROWSER_DOCKER_NETWORK=
# Live-session caps, 429 beyond (empty = unlimited). For `remote`, keep the fleet cap <= the number of sidecars.
EVERDICT_BROWSER_MAX_SESSIONS_PER_TENANT=
EVERDICT_BROWSER_MAX_SESSIONS=

# ── Optional: workspace GitHub App (github.com) ────────────────
# Create at https://github.com/settings/apps. Setup URL = ${API_PUBLIC_URL}/workspace/github-app/callback.
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=   # PEM; base64(PEM) recommended for single-line env-file safety
GITHUB_APP_SLUG=

# ── Optional: workspace GitHub App (GitHub Enterprise) ─────────
# ONE App on the single enterprise host for the whole deployment, handled identically to github.com
# (install-only — workspaces just click install + pick repos). All four required to enable.
GITHUB_ENTERPRISE_HOST=   # e.g. https://ghe.example.com
GITHUB_ENTERPRISE_APP_ID=
GITHUB_ENTERPRISE_APP_SLUG=
GITHUB_ENTERPRISE_APP_PRIVATE_KEY=   # PEM; base64(PEM) recommended for single-line env-file safety

# ── Optional: workspace Mattermost notifications ───────────────
# Operator-configured server URL; workspaces register only a bot token + channel in Settings › Integrations.
MATTERMOST_HOST=   # e.g. https://mattermost.example.com

# ═══════════════════════════════════════════════════════════════════════════════════════════════════════════════
# AUTH (multi-tenant SSO) — leave this whole block empty for single tenant=default (no login).
# To enable: fill the values below AND start with `--profile auth`, e.g.
#   docker compose -f deploy/compose/docker-compose.full.yaml --profile auth up -d --build
#
# ⚠️ Keycloak issuer must resolve to the SAME URL from the browser AND from the api/web containers.
#    `localhost` does NOT satisfy this (inside a container localhost = the container itself). Set PUBLIC_HOST to a
#    real host/IP reachable from both (e.g. your machine's LAN IP, or a hostname you add to /etc/hosts), and update
#    deploy/keycloak/realm-everdict.json redirectUris/webOrigins to that origin (currently http://localhost:3001).
# ═══════════════════════════════════════════════════════════════════════════════════════════════════════════════
# PUBLIC_HOST=192.168.1.50
# EVERDICT_REQUIRE_AUTH=1
# KEYCLOAK_ADMIN=admin
# KEYCLOAK_ADMIN_PASSWORD=admin
# API side (JWT verification):
# KEYCLOAK_ISSUER=http://192.168.1.50:8080/realms/everdict
# OIDC_AUDIENCE=
# WORKSPACE_CLAIM=workspace
# Web side (Auth.js token courier) — client id/secret come from realm-everdict.json:
# AUTH_SECRET=            # openssl rand -base64 32
# KEYCLOAK_CLIENT_ID=everdict-web
# KEYCLOAK_CLIENT_SECRET=everdict-web-secret

# ── Optional web extras ────────────────────────────────────────
# Temporal UI deep link — unset defaults to http://localhost:${TEMPORAL_UI_PORT}; the web rebases a loopback
# host onto the browser's request host, so the default works for remote users. Set only to pin a vanity/proxied URL.
# TEMPORAL_UI_URL=http://localhost:8233
# DESKTOP_DOWNLOAD_URL=https://github.com/everdict/everdict/releases/latest
