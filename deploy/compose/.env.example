# env for deploy/compose/docker-compose.prod.yaml. Copy it to .env:
#   cp deploy/compose/.env.example deploy/compose/.env
# (the dev compose needs almost no values — a token only when actually running the claude-code harness)
#
# Prebuilt image tag pulled from GHCR (api/web). Defaults to latest; pin a release e.g. 0.1.0.
# Ignored when you run `up --build` (builds from source instead).
EVERDICT_VERSION=
#
# Keycloak-less setup: the web operates as tenant=default and the API does not enforce auth. Assumes a trusted network.

# ── Ports ─────────────────────────────────────────────────────
WEB_PORT=3001
API_PORT=8787

# ── Postgres (required: password) ─────────────────────────────
POSTGRES_USER=everdict
POSTGRES_PASSWORD=change-me-postgres
POSTGRES_DB=everdict

# ── Control-plane API (optional) ──────────────────────────────
# Secret at-rest encryption KEK (base64, 32 bytes): openssl rand -base64 32. Leave empty to disable the secret store.
EVERDICT_SECRETS_KEY=
# Guard token for internal routes (/internal/**, minting tenant API keys): openssl rand -hex 32. Leave empty to disable those routes.
EVERDICT_INTERNAL_TOKEN=
# Per-tenant concurrent-run ceiling (optional). Leave empty for unlimited.
EVERDICT_TENANT_RUNS=

# ── Workspace GitHub App integration (github.com; org install → selected repos) ────────
# Everdict GitHub **App** credentials for github.com. Create at: https://github.com/settings/apps → New GitHub App.
#   Setup URL = ${API_PUBLIC_URL}/workspace/github-app/callback. Permissions: Contents·Pull requests·Administration.
# (GHE needs no env — an admin registers it per workspace under Settings › Integrations)
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=  # App private key (PEM); base64(PEM) recommended for single-line env-file safety
GITHUB_APP_SLUG=  # used in the install URL github.com/apps/<slug>/installations/new
# The externally reachable API base — the App install callback (Setup URL) base + the Mattermost inbound URL.
# ⚠️ On a new host, use this machine's real reachable host, not localhost. Leave empty to fall back to the request host (dev).
#   e.g. API_PUBLIC_URL=http://<your-host>:8787
API_PUBLIC_URL=
# The web base the browser is sent back to after the callback. Leave empty for http://localhost:3001 (dev default) → on an external host this jumps to the wrong place.
#   e.g. WEB_BASE_URL=http://<your-host>:3001
WEB_BASE_URL=

# ── Local backend run auth (optional) ─────────────────────────
# Only when LocalBackend runs the claude-code harness in-process. Can be replaced by the tenant SecretStore.
ANTHROPIC_API_KEY=
CLAUDE_CODE_OAUTH_TOKEN=
