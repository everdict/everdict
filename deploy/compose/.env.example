# deploy/compose/docker-compose.prod.yaml 용 env. 복사해서 .env 로:
#   cp deploy/compose/.env.example deploy/compose/.env
# (dev compose 는 값이 거의 필요 없음 — claude-code 하니스 실제 run 시에만 토큰)
#
# Keycloak 없는 구성: 웹은 tenant=default 로 동작, API 도 인증 미강제. 신뢰된 네트워크 전제.

# ── 포트 ──────────────────────────────────────────────────────
WEB_PORT=3001
API_PORT=8787

# ── Postgres (필수: 비밀번호) ─────────────────────────────────
POSTGRES_USER=assay
POSTGRES_PASSWORD=change-me-postgres
POSTGRES_DB=assay

# ── 컨트롤플레인 API (선택) ───────────────────────────────────
# 시크릿 at-rest 암호화 KEK(base64 32바이트): openssl rand -base64 32. 비우면 시크릿 저장소 비활성.
ASSAY_SECRETS_KEY=
# 내부 라우트(/internal/**, 테넌트 API 키 발급) 가드 토큰: openssl rand -hex 32. 비우면 해당 라우트 비활성.
ASSAY_INTERNAL_TOKEN=
# 테넌트별 동시 run 상한(선택). 비우면 무제한.
ASSAY_TENANT_RUNS=

# ── 워크스페이스 GitHub App 통합(github.com; 조직 설치→선택 repo) ────────
# github.com 용 Assay GitHub **App** 자격증명. 발급: https://github.com/settings/apps → New GitHub App.
#   Setup URL = ${API_PUBLIC_URL}/workspace/github-app/callback. 권한: Contents·Pull requests·Administration.
# (GHE 는 env 불필요 — 관리자가 설정 › 통합에서 워크스페이스별 등록)
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=  # App 개인키(PEM); env-file 단일행 안전성 위해 base64(PEM) 권장
GITHUB_APP_SLUG=  # 설치 URL github.com/apps/<slug>/installations/new 에 사용
# 외부에서 도달 가능한 API 베이스 — App 설치 콜백(Setup URL) 베이스 + Mattermost 인바운드 URL.
# ⚠️ 새 호스트에선 localhost 가 아니라 이 머신의 실제 접속 호스트로. 비우면 요청 호스트로 폴백(dev).
#   예) API_PUBLIC_URL=http://<your-host>:8787
API_PUBLIC_URL=
# 콜백 후 브라우저를 돌려보낼 웹 베이스. 비우면 http://localhost:3001(dev 기본) → 외부 호스트에선 엉뚱한 곳으로 튄다.
#   예) WEB_BASE_URL=http://<your-host>:3001
WEB_BASE_URL=

# ── 로컬 백엔드 run 인증(선택) ────────────────────────────────
# LocalBackend 가 claude-code 하니스를 in-process 로 돌릴 때만. 테넌트 SecretStore 로 대체 가능.
ANTHROPIC_API_KEY=
CLAUDE_CODE_OAUTH_TOKEN=
