# deploy/compose/docker-compose.prod.yaml 용 env. 복사해서 .env 로:
#   cp deploy/compose/.env.example deploy/compose/.env
# (dev compose 는 값이 거의 필요 없음 — claude-code 하니스 실제 run 시에만 토큰)
#
# Keycloak 없는 구성: 웹은 tenant=default 로 동작, API 도 인증 미강제. 신뢰된 네트워크 전제.

# ── 포트 ──────────────────────────────────────────────────────
WEB_PORT=3001
API_PORT=8787

# ── Postgres (필수: 비밀번호) ─────────────────────────────────
POSTGRES_USER=assay
POSTGRES_PASSWORD=change-me-postgres
POSTGRES_DB=assay

# ── 컨트롤플레인 API (선택) ───────────────────────────────────
# 시크릿 at-rest 암호화 KEK(base64 32바이트): openssl rand -base64 32. 비우면 시크릿 저장소 비활성.
ASSAY_SECRETS_KEY=
# 내부 라우트(/internal/**, 테넌트 API 키 발급) 가드 토큰: openssl rand -hex 32. 비우면 해당 라우트 비활성.
ASSAY_INTERNAL_TOKEN=
# 테넌트별 동시 run 상한(선택). 비우면 무제한.
ASSAY_TENANT_RUNS=

# ── 외부 계정 연결(Connected accounts, 아웃바운드 OAuth) ────────
# GitHub OAuth App(github.com) 자격증명. 비우면 GitHub 연결 비활성(기존 연결 조회/해제는 가능).
#   OAuth App 콜백 URL = ${API_PUBLIC_URL}/connections/callback
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
# 외부에서 도달 가능한 API 베이스 — OAuth redirect_uri 에 사용(provider 가 콜백할 주소). 비우면 요청 호스트로 폴백(dev).
API_PUBLIC_URL=
# 콜백 후 브라우저를 돌려보낼 웹 베이스. 비우면 http://localhost:3001(dev 기본).
WEB_BASE_URL=

# ── 로컬 백엔드 run 인증(선택) ────────────────────────────────
# LocalBackend 가 claude-code 하니스를 in-process 로 돌릴 때만. 테넌트 SecretStore 로 대체 가능.
ANTHROPIC_API_KEY=
CLAUDE_CODE_OAUTH_TOKEN=
