{
  "name": "assay",
  "license": "Apache-2.0",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "format": "biome format --write .",
    "lint": "biome check .",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "build": "turbo run build",
    "assay": "node --env-file-if-exists=.env apps/cli/dist/main.js",
    "api": "node --env-file-if-exists=apps/api/.env apps/api/dist/main.js",
    "api:dev": "node --watch --env-file-if-exists=apps/api/.env apps/api/dist/main.js",
    "api:start": "pnpm build && pnpm api",
    "keycloak": "KEYCLOAK_PORT=${KEYCLOAK_PORT:-8081} docker compose -f deploy/keycloak/docker-compose.yaml up -d",
    "keycloak:down": "docker compose -f deploy/keycloak/docker-compose.yaml down",
    "keycloak:reset": "docker compose -f deploy/keycloak/docker-compose.yaml down -v",
    "keycloak:logs": "docker compose -f deploy/keycloak/docker-compose.yaml logs -f keycloak"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.10.0",
    "turbo": "^2.3.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
