# apps/agent — the Everdict assistant service (the agentic loop behind the web chat + teammates).
# Copy to apps/agent/.env and fill in. Only CONTROL_PLANE_URL is required; everything else has a safe default.

# HTTP port the agent service listens on.
PORT=8790

# Control plane base URL — used for GET /me (identity) and, unless EVERDICT_MCP_URL is set, the MCP endpoint (<url>/mcp).
CONTROL_PLANE_URL=http://localhost:8787
# Override the MCP endpoint if it is not <CONTROL_PLANE_URL>/mcp.
# EVERDICT_MCP_URL=http://localhost:8787/mcp

# Shared Postgres (sessions + secrets + model registry + agent tokens). Unset → in-memory sessions + the env LLM
# fallback below, and teammates/agent-tokens are disabled (they need the shared everdict_tenant_keys table).
# DATABASE_URL=postgres://everdict:everdict@localhost:5434/everdict

# --- Model tiering (docs/architecture/agent-teams.md; the 7th gap axis) ---
# Claude Code does not use the large model for everything. These let the agent do the same: a registered workspace
# model id (needs DATABASE_URL + the workspace's provider secret) per tier. All optional — unset tiers reuse AGENT_MODEL.
# AGENT_MODEL=claude-opus-4-8          # the main model the agent runs on
# AGENT_SMALL_MODEL=claude-haiku-4-5   # cheaper model that digests compaction summaries (resolved only when compaction fires)
# AGENT_FALLBACK_MODEL=claude-sonnet-5 # takes over for the rest of a run if the main model keeps failing transiently
# AGENT_SUBAGENT_MODEL=claude-haiku-4-5 # cheaper model for spawn_agent sub-agents (delegated research rarely needs the main model)

# --- Eval-driving (S6) ---
# Opt the agent in to DRIVE eval: expose the curated write tools (run/retry scorecards, register/pin harnesses, create
# datasets/judges, schedule, …) beyond the default read-only + integration surface. Every such call is still
# HITL/plan/rule-gated and RBAC-bounded. Default off (read-only agent).
# AGENT_ALLOW_EVAL_DRIVE=true

# --- Proactive teams (S4 — the monitoring→team bridge) ---
# Shared secret the control plane (apps/api) presents as x-internal-token to POST /agent/events so a run/scorecard
# completion wakes the creator's watching teammates. MUST equal apps/api's AGENT_INTERNAL_TOKEN. Unset → the internal
# event path is disabled (only user-authenticated events work). Use a long random value.
# AGENT_INTERNAL_TOKEN=

# Per-tool wall-clock deadline (ms) — a tool that outruns it is aborted and returned as an error. Unset → no deadline.
# AGENT_TOOL_TIMEOUT_MS=120000

# Extended-thinking budget (tokens) — set → the agent reasons before answering. Anthropic requires >1024 and < max_tokens.
# AGENT_THINKING_BUDGET=4096

# Registered agent-config id resolved per workspace (instructions + MCP tool servers + model override). Default "default".
# AGENT_CONFIG_ID=default

# Cap on agentic-loop turns per run. Unset → the kernel default.
# AGENT_MAX_TURNS=50

# --- Env LLM fallback (no DB / no registered model) ---
# A raw provider endpoint the agent uses when no registered workspace model resolves. For local dev against LiteLLM/vLLM.
# AGENT_LLM_BASE_URL=http://localhost:4000
# AGENT_LLM_API_KEY=
# AGENT_LLM_MODEL=
