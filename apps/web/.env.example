# Control plane (@everdict/api) — called server-side only. The control plane owns auth/authz.
CONTROL_PLANE_URL=http://127.0.0.1:8787

# Auth.js (Keycloak). When unset, runs in dev mode (no auth, x-everdict-tenant=default).
# On login the web forwards the Keycloak access token to the control plane as Authorization: Bearer
# (the web is only a token courier — workspace/role come from the control plane's GET /me).
AUTH_SECRET=                 # `openssl rand -base64 32`
KEYCLOAK_ISSUER=             # http://localhost:8081/realms/everdict
KEYCLOAK_CLIENT_ID=          # everdict-web
KEYCLOAK_CLIENT_SECRET=      # everdict-web-secret (the client secret in realm-everdict.json)

# Allow the dev server's origin when accessing it over a LAN/Tailscale IP (unblocks HMR — next.config allowedDevOrigins)
EVERDICT_DEV_ORIGIN=   # e.g. 100.x.y.z

# Desktop app download (release) link — when set, shown under Account > Connected runners
DESKTOP_DOWNLOAD_URL=   # https://github.com/Ho2eny/everdict/releases/latest

# For the desktop download page (/{ws}/download) — the server reads a private release and 302-proxies it
DESKTOP_RELEASES_REPO=Ho2eny/everdict
DESKTOP_RELEASES_TOKEN=   # fine-grained PAT, contents:read (server-only secret)
