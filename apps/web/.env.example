# 컨트롤플레인(@assay/api) — 서버에서만 호출
CONTROL_PLANE_URL=http://127.0.0.1:8787

# Auth.js (Keycloak). 미설정 시 dev 모드(인증 없이 tenant="default")로 동작.
AUTH_SECRET=                 # `openssl rand -base64 32`
KEYCLOAK_ISSUER=             # http://localhost:8080/realms/assay
KEYCLOAK_CLIENT_ID=          # assay-web
KEYCLOAK_CLIENT_SECRET=
# Keycloak 토큰에서 tenant 를 읽을 클레임 이름 (기본 tenant)
TENANT_CLAIM=tenant
