# 컨트롤플레인(@everdict/api) — 서버에서만 호출. 인증/인가의 권위는 컨트롤플레인이 가진다.
CONTROL_PLANE_URL=http://127.0.0.1:8787

# Auth.js (Keycloak). 미설정 시 dev 모드(인증 없이 x-everdict-tenant=default)로 동작.
# 로그인하면 웹은 Keycloak 액세스 토큰을 컨트롤플레인에 Authorization: Bearer 로 그대로 전달한다
# (웹은 토큰 운반자일 뿐 — workspace/role 은 컨트롤플레인 GET /me 가 권위).
AUTH_SECRET=                 # `openssl rand -base64 32`
KEYCLOAK_ISSUER=             # http://localhost:8081/realms/everdict
KEYCLOAK_CLIENT_ID=          # everdict-web
KEYCLOAK_CLIENT_SECRET=      # everdict-web-secret (realm-everdict.json 의 클라이언트 시크릿)

# dev 서버를 LAN/Tailscale IP 로 접속할 때 그 origin 허용(HMR 차단 해제 — next.config allowedDevOrigins)
EVERDICT_DEV_ORIGIN=   # 예) 100.x.y.z

# 데스크톱 앱 다운로드(릴리즈) 링크 — 설정 시 계정>연결된 러너에 노출
DESKTOP_DOWNLOAD_URL=   # https://github.com/Ho2eny/everdict/releases/latest

# 데스크톱 다운로드 페이지(/{ws}/download)용 — private 릴리즈를 서버가 읽어 302 프록시
DESKTOP_RELEASES_REPO=Ho2eny/everdict
DESKTOP_RELEASES_TOKEN=   # fine-grained PAT, contents:read (서버 전용 비밀)
