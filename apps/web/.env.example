# 컨트롤플레인(@assay/api) — 서버에서만 호출. 인증/인가의 권위는 컨트롤플레인이 가진다.
CONTROL_PLANE_URL=http://127.0.0.1:8787

# Auth.js (Keycloak). 미설정 시 dev 모드(인증 없이 x-assay-tenant=default)로 동작.
# 로그인하면 웹은 Keycloak 액세스 토큰을 컨트롤플레인에 Authorization: Bearer 로 그대로 전달한다
# (웹은 토큰 운반자일 뿐 — workspace/role 은 컨트롤플레인 GET /me 가 권위).
AUTH_SECRET=                 # `openssl rand -base64 32`
KEYCLOAK_ISSUER=             # http://localhost:8081/realms/assay
KEYCLOAK_CLIENT_ID=          # assay-web
KEYCLOAK_CLIENT_SECRET=      # assay-web-secret (realm-assay.json 의 클라이언트 시크릿)

# 데스크톱 앱 다운로드(릴리즈) 링크 — 설정 시 계정>연결된 러너에 노출
DESKTOP_DOWNLOAD_URL=   # https://github.com/Ho2eny/assay/releases/latest
