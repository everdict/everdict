# apps/api 컨트롤플레인 서버 env. 복사해서 .env 로: cp apps/api/.env.example apps/api/.env
# `pnpm api` 가 이 파일을 읽는다(--env-file-if-exists=apps/api/.env). .env 는 gitignore.
# 대부분 비워둬도 dev 로 동작한다(인증 미강제 + in-memory 스토어). 필요한 것만 채우세요.
# (S3/Nomad/K8s/디렉터리·계측 등 선택 변수는 docs 참고 — 여기엔 두지 않는다.)

# ── 서버 ──────────────────────────────────────────────────────
PORT=8787
# Postgres(있으면 영속 + 기동 시 마이그레이션 적용). 비우면 in-memory → 재기동 시 데이터 휘발.
# 로컬 dev: deploy/postgres 를 띄우고(`bash scripts/dev/up.sh` 가 자동) 아래 값을 그대로 쓰면 된다.
DATABASE_URL=postgresql://everdict:everdict@localhost:5433/everdict

# ── 인증(선택; 비우면 dev 폴백 tenant=default, 인증 미강제) ────
# Keycloak OIDC issuer — 사람 로그인(JWT) 검증. 비우면 API 키만.
KEYCLOAK_ISSUER=
# 인증 필수화(dev 폴백 끄기): 1 이면 Bearer 없는 요청 401.
EVERDICT_REQUIRE_AUTH=
# 내부 라우트(/internal/**, 테넌트 API 키 발급) 가드: openssl rand -hex 32. 비우면 해당 라우트 비활성.
EVERDICT_INTERNAL_TOKEN=

# ── 시크릿 + 연결 토큰 at-rest 암호화 KEK ─────────────────────
# base64 32바이트: openssl rand -base64 32. 비우면 임시 키 자동생성(재기동마다 달라짐) —
# Postgres 영속 운영은 반드시 고정(고정 안 하면 재기동 후 기존 시크릿/연결 토큰 복호 불가).
EVERDICT_SECRETS_KEY=

# ── 워크스페이스 GitHub App 통합(github.com; 조직 설치→선택 repo) ──────
# github.com 용 Everdict GitHub **App** 자격증명 — 있으면 워크스페이스가 조직에 설치해 선택 repo 를 팀 공용으로 clone.
# (GHE 는 env 불필요 — 관리자가 설정 › 통합에서 host+App ID+개인키 SecretStore 이름을 워크스페이스별 등록)
# 발급: https://github.com/settings/apps → New GitHub App. Setup URL = ${API_PUBLIC_URL}/workspace/github-app/callback
#   권한: Contents(read/write) · Pull requests(write) · Administration(read/write, 러너 등록용). "Request user auth" 불필요.
GITHUB_APP_ID=
# App 개인키(PEM). env-file 단일행 안전성 위해 base64(PEM) 권장; "BEGIN" 포함이면 raw PEM(\n 이스케이프)도 허용.
GITHUB_APP_PRIVATE_KEY=
# App slug(설치 URL github.com/apps/<slug>/installations/new 에 사용).
GITHUB_APP_SLUG=
# 외부에서 도달 가능한 API 베이스 — App 설치 콜백(Setup URL) 베이스 + Mattermost 인바운드 URL.
# ⚠️ 새 호스트에선 localhost 가 아니라 이 머신의 실제 접속 호스트로. 비우면 요청 호스트로 폴백(dev 전용).
#   예) API_PUBLIC_URL=http://<your-host>:8787
API_PUBLIC_URL=
# 콜백 후 브라우저를 돌려보낼 웹(apps/web) 베이스. 비우면 http://localhost:3001 → 외부 호스트에선 엉뚱한 곳으로 튄다.
#   예) WEB_BASE_URL=http://<your-host>:3001
WEB_BASE_URL=
