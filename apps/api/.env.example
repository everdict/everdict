# apps/api 컨트롤플레인 서버 env. 복사해서 .env 로: cp apps/api/.env.example apps/api/.env
# `pnpm api` 가 이 파일을 읽는다(--env-file-if-exists=apps/api/.env). .env 는 gitignore.
# 대부분 비워둬도 dev 로 동작한다(인증 미강제 + in-memory 스토어). 필요한 것만 채우세요.
# (S3/Nomad/K8s/디렉터리·계측 등 선택 변수는 docs 참고 — 여기엔 두지 않는다.)

# ── 서버 ──────────────────────────────────────────────────────
PORT=8787
# Postgres(있으면 영속 + 기동 시 마이그레이션 적용). 비우면 in-memory.
DATABASE_URL=

# ── 인증(선택; 비우면 dev 폴백 tenant=default, 인증 미강제) ────
# Keycloak OIDC issuer — 사람 로그인(JWT) 검증. 비우면 API 키만.
KEYCLOAK_ISSUER=
# 인증 필수화(dev 폴백 끄기): 1 이면 Bearer 없는 요청 401.
ASSAY_REQUIRE_AUTH=
# 내부 라우트(/internal/**, 테넌트 API 키 발급) 가드: openssl rand -hex 32. 비우면 해당 라우트 비활성.
ASSAY_INTERNAL_TOKEN=

# ── 시크릿 + 연결 토큰 at-rest 암호화 KEK ─────────────────────
# base64 32바이트: openssl rand -base64 32. 비우면 임시 키 자동생성(재기동마다 달라짐) —
# Postgres 영속 운영은 반드시 고정(고정 안 하면 재기동 후 기존 시크릿/연결 토큰 복호 불가).
ASSAY_SECRETS_KEY=

# ── 외부 계정 연결(Connected accounts, 아웃바운드 OAuth) ──────
# GitHub OAuth App(github.com) 자격증명. 비우면 github.com 원클릭 비활성(기존 연결 조회/해제는 가능).
#   OAuth App 콜백 URL = ${API_PUBLIC_URL}/connections/callback
# (GitHub Enterprise·Mattermost 는 env 불필요 — 연결할 때 host + 워크스페이스 SecretStore 의 client_secret 키 이름을 입력)
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
# 외부에서 도달 가능한 API 베이스 — OAuth redirect_uri 에 사용(provider 가 콜백할 주소).
# 비우면 요청 호스트로 폴백(dev). 운영/외부 provider 연결엔 필수.
API_PUBLIC_URL=
# 콜백 후 브라우저를 돌려보낼 웹 베이스. 비우면 http://localhost:3001.
WEB_BASE_URL=
