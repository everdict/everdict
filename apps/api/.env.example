# apps/api control-plane server env. Copy to .env: cp apps/api/.env.example apps/api/.env
# `pnpm api` reads this file (--env-file-if-exists=apps/api/.env). .env is gitignored.
# Most can stay empty for dev (auth not enforced + in-memory stores). Fill in only what you need.
# (Optional vars like S3/Nomad/K8s/directory·metering: see the docs — not kept here.)

# ── Server ────────────────────────────────────────────────────
PORT=8787
# Postgres (if set: persistent + migrations applied on boot). Empty = in-memory → data is lost on restart.
# Local dev: bring up deploy/postgres (`bash scripts/dev/up.sh` does it automatically) and use the value below as-is.
DATABASE_URL=postgresql://everdict:everdict@localhost:5433/everdict

# ── Auth (optional; empty = dev fallback tenant=default, auth not enforced) ────
# Keycloak OIDC issuer — verifies human login (JWT). Empty = API keys only.
KEYCLOAK_ISSUER=
# Require auth (disable the dev fallback): 1 = requests without a Bearer get 401.
EVERDICT_REQUIRE_AUTH=
# Guard for internal routes (/internal/**, tenant API-key issuance): openssl rand -hex 32. Empty disables those routes.
EVERDICT_INTERNAL_TOKEN=

# ── At-rest encryption KEK for secrets + connection tokens ────
# base64 32 bytes: openssl rand -base64 32. Empty auto-generates an ephemeral key (changes on every restart) —
# For persistent Postgres operation you MUST fix this (otherwise existing secrets/connection tokens can't be decrypted after a restart).
EVERDICT_SECRETS_KEY=

# ── Workspace GitHub App integration (github.com; org install→selected repos) ──────
# Everdict GitHub **App** credentials for github.com — if set, a workspace can install it on an org and clone selected repos for the team.
# (GHE needs no env — an admin registers host+App ID+private-key SecretStore name per workspace under Settings › Integrations)
# Create at: https://github.com/settings/apps → New GitHub App. Setup URL = ${API_PUBLIC_URL}/workspace/github-app/callback
#   Permissions: Contents(read/write) · Pull requests(write) · Administration(read/write, for runner registration). "Request user auth" not needed.
GITHUB_APP_ID=
# App private key (PEM). base64(PEM) is recommended for single-line env-file safety; a raw PEM (escaped \n) is also allowed if it contains "BEGIN".
GITHUB_APP_PRIVATE_KEY=
# App slug (used in the install URL github.com/apps/<slug>/installations/new).
GITHUB_APP_SLUG=
# Externally reachable API base — the App install callback (Setup URL) base + the Mattermost inbound URL.
# ⚠️ On a new host, use this machine's actual reachable host, not localhost. Empty falls back to the request host (dev only).
#   e.g. API_PUBLIC_URL=http://<your-host>:8787
API_PUBLIC_URL=
# Web (apps/web) base to return the browser to after the callback. Empty = http://localhost:3001 → sends you to the wrong place on an external host.
#   e.g. WEB_BASE_URL=http://<your-host>:3001
WEB_BASE_URL=

# --- Agent event bridge (proactive teams — docs/architecture/agent-teams.md S4) ---
# With BOTH set, a run/scorecard completion also pushes a platform event to the agent service, waking the
# creator's teammates that watch that kind. Unset → skipped (the personal feed + Mattermost are unaffected).
# The token must MATCH apps/agent's AGENT_INTERNAL_TOKEN — it authenticates this control-plane→agent call so the
# agent will fan an event to any recipient (no per-request user bearer).
#   e.g. AGENT_SERVICE_URL=http://<your-host>:8791
AGENT_SERVICE_URL=
AGENT_INTERNAL_TOKEN=
