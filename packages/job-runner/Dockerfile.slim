# Slim job-runner (multi-stage, pnpm deploy) — node + git only; the job-runner dist with prod deps (~330MB vs ~5GB).
# For runtimes whose harnesses bring their own toolchain (case.image) or run pure-shell commands: RuntimeSpec.image
# picks the job-runner image per runtime, so the batteries-included default (Dockerfile: claude CLI + python + aider)
# stays optional. Build (repo root): docker build -f packages/job-runner/Dockerfile.slim -t <registry>/everdict-job-runner:slim .
FROM node:22-bookworm-slim AS build
RUN corepack enable
WORKDIR /app
COPY . .
RUN pnpm install --frozen-lockfile \
  && pnpm --filter @everdict/job-runner... build \
  && pnpm --filter @everdict/job-runner --prod deploy /out

FROM node:22-bookworm-slim
RUN apt-get update && apt-get install -y --no-install-recommends git ca-certificates && rm -rf /var/lib/apt/lists/*
COPY --from=build /out /app
WORKDIR /app
# CaseJob is injected via the EVERDICT_CASE_JOB env (base64 JSON) — same contract as the full image.
ENTRYPOINT ["node", "dist/main.js"]
