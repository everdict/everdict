# Copy to .env (.env is gitignored). Most can be left blank —
# LocalDriver uses this machine's claude subscription login as-is.

# Only needed when running claude-code in sandbox jobs without a login (Nomad/K8s, etc.) or in CI:
# ANTHROPIC_API_KEY=

EVERDICT_TIMEOUT_SEC=300

# --- Workspace integrations (operator-configured, optional) ---
# Public base URLs used by the GitHub App install callback + Mattermost inbound URLs.
# API_PUBLIC_URL=https://api.everdict.example.com
# WEB_BASE_URL=https://app.everdict.example.com
#
# GitHub App — ONE App per host for the whole deployment; workspaces just install + pick repos.
# github.com App (register at https://github.com/settings/apps). PRIVATE_KEY = base64(PEM) or raw PEM.
# GITHUB_APP_ID=
# GITHUB_APP_SLUG=everdict-eval
# GITHUB_APP_PRIVATE_KEY=
# GitHub Enterprise App — the single enterprise host, handled identically to github.com (install-only).
# GITHUB_ENTERPRISE_HOST=https://ghe.example.com
# GITHUB_ENTERPRISE_APP_ID=
# GITHUB_ENTERPRISE_APP_SLUG=everdict-eval
# GITHUB_ENTERPRISE_APP_PRIVATE_KEY=
#
# Mattermost — the server URL is operator-configured; workspaces register only a bot token + channel.
# MATTERMOST_HOST=https://mattermost.example.com
